#!/usr/bin/env bash
# Displays subdomain DNS information

# Install dig if not available
if ! command -v dig &> /dev/null; then
    apt-get update -y
    apt-get install -y dnsutils 2>/dev/null || apt-get install -y bind9-dnsutils
fi

get_subdomain_info() {
    local domain=$1
    local subdomain=$2
    local result
    result=$(dig "$subdomain.$domain" | awk '/ANSWER SECTION:/{getline; print}')
    local record_type
    record_type=$(echo "$result" | awk '{print $4}')
    local destination
    destination=$(echo "$result" | awk '{print $5}')
    echo "The subdomain $subdomain is a $record_type record and points to $destination"
}

domain=$1
subdomain=$2

if [ -z "$subdomain" ]; then
    get_subdomain_info "$domain" "www"
    get_subdomain_info "$domain" "lb-01"
    get_subdomain_info "$domain" "web-01"
    get_subdomain_info "$domain" "web-02"
else
    get_subdomain_info "$domain" "$subdomain"
fi
